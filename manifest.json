{
  "manifest_version": 3,
  "name": "Weibo Clipper for Obsidian",
  "description": "在微博页面为每条微博增加一个保存按钮，并将内容写入本地 Obsidian 库。",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://weibo.com/*",
    "https://www.weibo.com/*",
    "https://*.sinaimg.cn/*",
    "https://*.weibocdn.com/*",
    "https://*.weibo.cn/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "options_page": "src/options/options.html",
  "action": {
    "default_title": "Weibo Clipper",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://weibo.com/*",
        "https://www.weibo.com/*"
      ],
      "css": [
        "src/content/content.css"
      ],
      "js": [
        "src/shared/core.js",
        "src/content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
